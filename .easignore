# ==============================
# EAS BUILD IGNORE - KOSHER APP
# ==============================
# Este archivo NO se ejecuta. EAS lo lee automaticamente al subir el proyecto.
# Objetivo: evitar subir cache, builds, zips, backups y contenido offline descargado.

# Dependencias locales
node_modules/

# Expo local state
.expo/
.expo-shared/

# Builds nativos/generados
android/
ios/
dist/
build/
web-build/

# Archivos generados por builds
*.apk
*.aab
*.ipa
*.tar
*.tgz
*.zip
*.rar
*.7z

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Git / sistema operativo
.git/
.DS_Store
Thumbs.db

# Caches / temporales
.cache/
.tmp/
tmp/
temp/
coverage/

# Contenido descargado offline en desarrollo
# IMPORTANTE: NO ignorar src/offline porque ahi hay codigo real de la app.
offline_data/
offline-images/
offline_images/
downloads/
downloaded/
cache/
assets/offline/
assets/cache/
assets/downloads/
*.part

# Variables locales
.env
.env.*
!.env.example
